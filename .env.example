# Required: OpenAI-compatible chat model
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://your-api-endpoint/v1
OPENAI_MODEL=your_model

# Optional: web search (configure one or more; comma-separate multiple keys)
TAVILY_API_KEYS=
BRAVE_API_KEYS=
SERPAPI_API_KEYS=

# Optional: Alpaca market data
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Optional: social sentiment service
SOCIAL_SENTIMENT_API_KEY=
SOCIAL_SENTIMENT_API_URL=

# Optional: embeddings
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# Optional: reranking
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=

# Optional: set to DEBUG to enable verbose application logs
INFO=
